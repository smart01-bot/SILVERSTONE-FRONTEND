{
  "expo": {
    "name": "Silverstone",
    "slug": "silverstone",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#D32F2F"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D32F2F"
      },
      "package": "com.silverstone.floatmanager"
    },
    "ios": {
      "bundleIdentifier": "com.silverstone.floatmanager"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      ["expo-notifications", { "color": "#D32F2F" }]
    ],
  }
}
