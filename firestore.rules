rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Agents can read their own doc
    // Main agents can read all docs
    match /agents/{agentId} {
      allow read: if request.auth != null && (
        request.auth.uid == agentId ||
        get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == 'main-agent'
      );
      allow create: if request.auth.uid == agentId;
      allow update: if request.auth.uid == agentId ||
        get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == 'main-agent';
    }

    // Requests
    match /requests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.agentId == request.auth.uid ||
        get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == 'main-agent'
      );
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == 'main-agent';
    }

    // Transactions
    match /transactions/{txId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == 'main-agent';
    }
  }
}
